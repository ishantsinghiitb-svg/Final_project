# App
VITE_APP_ENV=development

# Supabase — must match the main NextOffer app's project
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# NextOffer web app — used for the auth bridge and "Open in NextOffer" links.
# Update if the app runs on a different port/host.
VITE_APP_URL=http://localhost:8080
