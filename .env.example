# Supabase
# Find these in your Supabase project: Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Module 6A · AI Foundation (server-only) ──
# These are SECRETS — do NOT prefix with VITE_ (that would ship them to the
# browser). In dev they come from the Node process env; in production set them
# as Cloudflare Worker secrets: `npx wrangler secret put OPENAI_API_KEY`, etc.
OPENAI_API_KEY=your-openai-api-key
# Optional alternate providers (stubs in the MVP):
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# Optional: service-role client for privileged server paths (bypasses RLS).
# SUPABASE_SERVICE_ROLE_KEY=

# ── Module 6A · AI config (isomorphic, safe to expose) ──
# Default AI provider: openai | anthropic | gemini
VITE_AI_DEFAULT_PROVIDER=openai
# Free AI generations per new user before the feature locks.
VITE_AI_FREE_CREDITS=3
